rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == 'admin';
    }

    function ownsRestaurant(slug) {
      return isSignedIn() && userDoc().data.restaurantSlug == slug;
    }

    // Restaurantes — leitura pública (cardápio renderizado em sites externos),
    // escrita só admin ou owner do slug
    match /restaurants/{slug} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || ownsRestaurant(slug);

      match /data/{docId} {
        allow read: if true;
        allow write: if isAdmin() || ownsRestaurant(slug);
      }

      // Leads: apenas admin e owner leem (contêm UTMs/UA/referrer)
      // Worker escreve via service account (bypassa rules)
      match /leads/{leadId} {
        allow read: if isAdmin() || ownsRestaurant(slug);
        allow write: if false;
      }

      match /{subcollection}/{docId} {
        allow read: if true;
        allow write: if isAdmin() || ownsRestaurant(slug);
      }
    }

    // Contratos — só admin
    match /contracts/{slug} {
      allow read, write: if isAdmin();
    }

    // Tokens OAuth, integrações — só admin
    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    // Config tenants (TENANTS migrado pra Firestore) — leitura pelo Worker via service account
    // (bypassa rules), admin gerencia no painel
    match /tenantConfig/{slug} {
      allow read: if isAdmin() || ownsRestaurant(slug);
      allow write: if isAdmin();
    }

    // Usuários — user lê próprio doc, admin gerencia tudo.
    // Usuário não pode auto-promover role nem trocar restaurantSlug.
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (request.auth.uid == userId
            && request.resource.data.role == resource.data.role
            && request.resource.data.restaurantSlug == resource.data.restaurantSlug);
    }
  }
}
